# Copie este arquivo como .env e ajuste os valores para seu ambiente.
# O docker-compose.yml já possui defaults seguros para desenvolvimento local —
# este arquivo só é necessário se quiser sobrescrever algum valor.

# ─── PostgreSQL ───
DB_PASSWORD=postgres

# ─── Backend: JWT ───
# Gere um segredo forte para produção: openssl rand -hex 32
JWT_SECRET=3f5a8d2b1e7c4f9a0b6d3e8c2f1a5b9d4e7f0c3a6b9d2e5f8c1a4b7d0e3f6a9
JWT_EXPIRATION=86400000          # 1 dia em ms
REFRESH_TOKEN_EXPIRATION=604800000  # 7 dias em ms

# ─── Backend: admin inicial ───
ADMIN_EMAIL=admin@store.com
ADMIN_PASSWORD=admin123

# ─── Frontend: URLs da API (embutidas no bundle pelo Vite em tempo de build) ───
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_URL=http://localhost:8080/ws
